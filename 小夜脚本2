local scriptButtons = {}

local function AddDivider(group)
    group:AddLabel("────────────────────")
end

local function CreateScriptButton(group, scriptName, scriptUrl, isLeft)
    local btn = group:AddButton({
        Text = scriptName,
        Func = function()
            Library:Notify("正在加载: " .. scriptName, 3)
            local success, result = pcall(function()
                loadstring(game:HttpGet(scriptUrl))()
            end)
            if success then
                Library:Notify("脚本加载成功: " .. scriptName, 3)
            else
                Library:Notify("加载失败: " .. tostring(result), 5)
            end
        end,
        DoubleClick = false,
    })
    return btn
end

local function DistributeScripts()
    local leftIndex = 1
    local rightIndex = 1
    local totalScripts = 0
    
    for _, category in ipairs(scriptCategories) do
        totalScripts = totalScripts + #category.List
    end
    
    local leftCount = math.ceil(totalScripts / 2)
    local currentCount = 0
    local isLeft = true
    
    for _, category in ipairs(scriptCategories) do
        local title = "【" .. category.GroupName .. "】"
        
        if isLeft then
            ScriptLeftGroup:AddLabel(title)
            AddDivider(ScriptLeftGroup)
        else
            ScriptRightGroup:AddLabel(title)
            AddDivider(ScriptRightGroup)
        end
        
        for _, script in ipairs(category.List) do
            if isLeft then
                CreateScriptButton(ScriptLeftGroup, script.Name, script.Url, true)
            else
                CreateScriptButton(ScriptRightGroup, script.Name, script.Url, false)
            end
            
            currentCount = currentCount + 1
            if currentCount >= leftCount then
                isLeft = false
            end
        end
    end
end

DistributeScripts()

