            highlight.Adornee = plr.Character
            highlight.Parent = hrp
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.FillColor = Color3.fromRGB(255, 0, 0)
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)           
            highlight.FillTransparency = 0.5
            highlight.OutlineTransparency = 0            
            highlights[plr] = highlight
        end
        local function clearHighlights()
            for plr, highlight in pairs(highlights) do
                if highlight and highlight.Parent then
                    highlight:Destroy()
                end
            end
            table.clear(highlights)
        end
        local function clearConnections()
            for _, conn in pairs(connections) do
                if typeof(conn) == "RBXScriptConnection" then
                    conn:Disconnect()
                end
            end
            table.clear(connections)
        end
        local function setupCharacterTracking(plr)
            if connections["Char_" .. plr.UserId] then
                return
            end           
            local charConn = plr.CharacterAdded:Connect(function(character)
                task.wait(0.1)                
                if enabled then
                    createHighlight(plr)
                end
            end)           
            connections["Char_" .. plr.UserId] = charConn
        end
        if enabled then
            for _, plr in pairs(Players:GetPlayers()) do
                task.spawn(function()
                    if plr.Character then
                        repeat task.wait() until plr.Character:FindFirstChild("HumanoidRootPart")
                        createHighlight(plr)
                    end
                    setupCharacterTracking(plr)
                end)
            end
            connections["PlayerAdded"] = Players.PlayerAdded:Connect(function(plr)
                task.spawn(function()
                    if plr.Character then
                        repeat task.wait() until plr.Character:FindFirstChild("HumanoidRootPart")
                        createHighlight(plr)
                    end
                    setupCharacterTracking(plr)
                end)
            end)
            connections["PlayerRemoving"] = Players.PlayerRemoving:Connect(function(plr)
                if highlights[plr] then
                    highlights[plr]:Destroy()
                    highlights[plr] = nil
                end
                if connections["Char_" .. plr.UserId] then
                    connections["Char_" .. plr.UserId]:Disconnect()
                    connections["Char_" .. plr.UserId] = nil
                end
            end)

        else
            clearHighlights()
            clearConnections()
        end
    end
})
