	}
}
local lastAttack = 0
local function isTeammate(plr)
	return SETTINGS.IgnoreTeammates
		and plr.Team
		and plr.Team == LocalPlayer.Team
end
local function angleBetween(v1, v2)
	return math.acos(v1:Dot(v2))
end
local function canHit(origin, targetPos, ignore)
	local ray = RaycastParams.new()
	ray.FilterType = Enum.RaycastFilterType.Blacklist
	ray.FilterDescendantsInstances = ignore or {}
	local result = Workspace:Raycast(origin, targetPos - origin, ray)
	return not result or result.Instance:IsDescendantOf(LocalPlayer.Character)
end
local function getFireRate(dist)
	if dist < 15 then
		return SETTINGS.FireRateClose
	elseif dist < 40 then
		return SETTINGS.FireRateMid
	else
		return SETTINGS.FireRateFar
	end
end
local function getRandomHitPart(character)
	local total = 0
	for _, w in pairs(SETTINGS.HitParts) do
		total += w
	end
	local r = math.random() * total
	local cumulative = 0
	for partName, weight in pairs(SETTINGS.HitParts) do
		cumulative += weight
		if r <= cumulative then
			return character:FindFirstChild(partName)
		end
	end
	return character:FindFirstChild("HumanoidRootPart")
end
local function shouldMiss()
	return math.random() < SETTINGS.MissChance
end
local function shouldIdle()
	return math.random() < SETTINGS.IdleChance
end
local function getMissedPosition(realPos, dist)
	local offset = SETTINGS.MissOffsetMin
		+ math.random() * (SETTINGS.MissOffsetMax - SETTINGS.MissOffsetMin)
	offset *= math.clamp(dist / 35, 0.7, 2.2)
	local angle = math.random() * math.pi * 2
	local ox = math.cos(angle) * offset
	local oy = math.sin(angle) * offset

	return realPos + Vector3.new(ox, oy, 0)
end
local function showBullet(origin, hitPos)
	local part = Instance.new("Part")
	part.Anchored = true
	part.CanCollide = false
	part.Size = Vector3.new(0.06, 0.06, (hitPos - origin).Magnitude)
	part.CFrame = CFrame.new(origin, hitPos) * CFrame.new(0, 0, -part.Size.Z / 2)
	part.Color = Color3.fromRGB(255, 210, 50)
	part.Transparency = 0.3
	part.Material = Enum.Material.Neon
	part.Parent = Workspace

	Debris:AddItem(part, SETTINGS.BulletLifeTime)
end
local function fireAttack(targetPart)
	local origin = Camera.CFrame.Position
	local realHitPos = targetPart.Position
	local dist = (realHitPos - origin).Magnitude
	local hitPos
	if shouldMiss() then
		hitPos = getMissedPosition(realHitPos, dist)
	else
		hitPos = realHitPos
	end
	local direction = (hitPos - origin).Unit
	showBullet(origin, hitPos)
	local args = {
		{
			direction = direction,
			hitPosition = hitPos,
			origin = origin,
			hitInstance = targetPart,
			hitHumanoid = targetPart.Parent:FindFirstChild("Humanoid"),
			IsHeadshot = false
		}
	}
	ReplicatedStorage
		:WaitForChild("SystemResources")
		:WaitForChild("BufferCache")
		:WaitForChild("RequestActionSync")
		:FireServer(unpack(args))
end
local function getBestTarget()
	local char = LocalPlayer.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then
		return nil, nil, math.huge
	end
	local origin = Camera.CFrame.Position
	local lookVec = Camera.CFrame.LookVector
	local bestPlr, bestPart, bestDist = nil, nil, SETTINGS.MaxRange
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer and not isTeammate(plr) and plr.Character then
			local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local dir = (hrp.Position - origin).Unit
				local angle = math.deg(angleBetween(lookVec, dir))
				if angle < SETTINGS.FovDeg then
					local dist = (hrp.Position - origin).Magnitude
					if dist < bestDist then
						local part = getRandomHitPart(plr.Character)
						if part and canHit(origin, part.Position, {char, plr.Character}) then
							bestDist = dist
							bestPlr = plr
							bestPart = part
						end
					end
				end
			end
		end
	end
	return bestPlr, bestPart, bestDist
end
RunService.RenderStepped:Connect(function()
	if not SETTINGS.Enabled then return end
	if shouldIdle() then return end
	local _, targetPart, dist = getBestTarget()
	if not targetPart then return end
	local rate = getFireRate(dist)
	rate = math.max(rate, SETTINGS.MinAttackDelay)
	rate += math.random(-10, 10) / 100
	if tick() - lastAttack < rate then return end
	fireAttack(targetPart)
	lastAttack = tick()
end)
