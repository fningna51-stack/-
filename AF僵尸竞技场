local activeZombies = {}
local lastHit = {}

local function tryTrack(obj)
    if not obj:IsA("Model") then return end
    if not obj.Name:find("Zombie") then return end
    if activeZombies[obj] then return end
    local id = tonumber(obj.Name:match("Zombie_(%d+)"))
    if id then
        activeZombies[obj] = id
    end
end

local function tryUntrack(obj)
    if obj:IsA("Model") then
        local id = activeZombies[obj]
        if id then
            lastHit[id] = nil
        end
        activeZombies[obj] = nil
    end
end

for _, obj in ipairs(zombieContainer:GetChildren()) do
    tryTrack(obj)
end

zombieContainer.ChildAdded:Connect(tryTrack)
zombieContainer.ChildRemoved:Connect(tryUntrack)

task.spawn(function()
    while true do
        task.wait(0.5)
        for _, obj in ipairs(zombieContainer:GetChildren()) do
            tryTrack(obj)
        end
        for model in pairs(activeZombies) do
            if not model or not model.Parent then
                tryUntrack(model)
            end
        end
    end
end)

local function isHoldingGun()
    local char = lp.Character
    if not char then return false end
    local tool = char:FindFirstChildOfClass("Tool")
    return tool and tool.Name:find(WEAPON_NAME) ~= nil
end

local function getMuzzlePosition()
    local char = lp.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    return root.Position + root.CFrame.LookVector * 2
end

local autoKillEnabled = false
local autoKillConn = nil

local function startAutoKill()
    if autoKillConn then return end
    autoKillConn = RunService.Heartbeat:Connect(function()
        if not autoKillEnabled then return end

        local now = tick()
        local char = lp.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        local targets = {}
        for model, id in pairs(activeZombies) do
            if not model or not model.Parent then
                tryUntrack(model)
                continue
            end

            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health <= 0 then
                tryUntrack(model)
                continue
            end

            if lastHit[id] and (now - lastHit[id]) < HIT_COOLDOWN then
                continue
            end

            table.insert(targets, { id = id })
        end

        table.sort(targets, function(a, b)
            return a.id < b.id
        end)

        local limit = math.min(#targets, PROCESS_RATE)
        for i = 1, limit do
            local id = targets[i].id
            lastHit[id] = now
            damageRemote:FireServer(id, MAX_DAMAGE)
        end
    end)
end

local function stopAutoKill()
    if autoKillConn then
        autoKillConn:Disconnect()
        autoKillConn = nil
    end
end

local gunKillEnabled = false
local gunKillConn = nil

local function startGunKill()
    if gunKillConn then return end
    gunKillConn = RunService.RenderStepped:Connect(function()
        if not gunKillEnabled then return end
        if not isHoldingGun() then return end

        local char = lp.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        local muzzle = getMuzzlePosition()
        if not root or not muzzle then return end

        local now = tick()
        local targets = {}

        for model, id in pairs(activeZombies) do
            if not model or not model.Parent then
                tryUntrack(model)
                continue
            end

            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health <= 0 then
                tryUntrack(model)
                continue
            end

            local part =
                model.PrimaryPart
                or model:FindFirstChild("HumanoidRootPart")
                or model:FindFirstChildWhichIsA("BasePart")

            if not part then continue end

            if lastHit[id] and (now - lastHit[id]) < HIT_COOLDOWN then
                continue
            end

            table.insert(targets, {
                id = id,
                pos = part.Position
            })
        end

        table.sort(targets, function(a, b)
            return (a.pos - root.Position).Magnitude < (b.pos - root.Position).Magnitude
        end)

        local limit = math.min(#targets, PROCESS_RATE)
        for i = 1, limit do
            local t = targets[i]
            lastHit[t.id] = now
            local dir = (t.pos - muzzle).Unit
            GunFire:FireServer(WEAPON_NAME, muzzle, dir)
            GunHit:FireServer(WEAPON_NAME, t.id, t.pos, MAX_DAMAGE)
        end
    end)
end

local function stopGunKill()
    if gunKillConn then
        gunKillConn:Disconnect()
        gunKillConn = nil
    end
end

