        end)
        return TextBox
    end

    function PanelAPI:CreateSubTab(subTitle)
        local subOffset = currentHoloOffset * CFrame.new(2.8, 0, 0)
        local SubPanel = CreateSpatialPanel(subTitle, subOffset, false)
        
        local Btn = Instance.new("TextButton")
