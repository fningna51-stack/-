    end
    
    local MainLabel, TimeGui = createTimeLabel()
    local fpsTable = {}
    local hue = 0
    local frameTime = tick()
    local lastTick = tick()
    local Heartbeat = game:GetService("RunService").Heartbeat
    
    local function UpdateTimeLabel()
        lastTick = tick()
        
        for i = #fpsTable, 1, -1 do
            fpsTable[i + 1] = fpsTable[i] >= lastTick - 1 and fpsTable[i] or nil
        end
        fpsTable[1] = lastTick
        
        local fps = tick() - frameTime >= 1 and #fpsTable or #fpsTable / (tick() - frameTime)
        local _ = fps - fps % 1
        
        MainLabel.Text = ("秋辞时间:" .. os.date("%H") .. "时" .. os.date("%M") .. "分" .. os.date("%S")) .. "秒"
        
        MainLabel.TextColor3 = Color3.fromHSV(hue, 1, 1)
        hue = (hue + 0.001) % 1
    end
    
    frameTime = tick()
    Heartbeat:Connect(UpdateTimeLabel)
    
    game:GetService("CoreGui").ChildRemoved:Connect(function(child)
        if child.Name == "TimeDisplayGUI" then
            createTimeLabel()
        end
    end)
end
