local function CreateCircleVisualizer(audioObject, targetPlayer)
    local bars = {}
    local numBars = 24
    local radius = 3.0
    local attachTarget = targetPlayer or game.Players.LocalPlayer
    
    for i = 1, numBars do
        local bar = Instance.new("Part")
        bar.Anchored = true
        bar.CanCollide = false
        bar.Material = Enum.Material.Neon
        bar.Color = Color3.fromRGB(10, 132, 255)
        bar.Size = Vector3.new(0.1, 0.1, 0.1)
        Instance.new("BlockMesh", bar)
        bar.Parent = workspace
        table.insert(bars, bar)
    end
    
    local connection = RunService.RenderStepped:Connect(function(dt)
        if not audioObject or not audioObject.Parent then
            for _, bar in ipairs(bars) do
                bar.CFrame = CFrame.new(0, -9999, 0)
            end
            return
        end
        
        local loudness = audioObject.PlaybackLoudness
        local normalized = math.clamp(loudness / 400, 0.05, 1)
        
        local centerCFrame = CFrame.new(0, -9999, 0)
        local character = attachTarget and attachTarget.Character
        
        if character and character:FindFirstChild("HumanoidRootPart") then
            centerCFrame = character.HumanoidRootPart.CFrame * CFrame.new(0, -2, 0)
        else
            for _, bar in ipairs(bars) do
                bar.CFrame = CFrame.new(0, -9999, 0)
            end
            return
        end
        
        local globalRotation = tick() * 0.8
        
        for i, bar in ipairs(bars) do
            local noise = math.noise(tick() * 4, i * 0.15, 0)
            local scale = math.clamp(normalized + (noise * normalized * 0.6), 0.05, 1)
            
            local targetHeight = scale * 5.0
            bar.Size = bar.Size:Lerp(Vector3.new(0.15, targetHeight, 0.15), 0.3)
            
            local angle = (i / numBars) * math.pi * 2 + globalRotation
            local offsetX = math.cos(angle) * radius
            local offsetZ = math.sin(angle) * radius
            
            local barPos = centerCFrame.Position + Vector3.new(offsetX, 0, offsetZ)
            local lookAtPos = Vector3.new(centerCFrame.Position.X, barPos.Y, centerCFrame.Position.Z)
            local targetCFrame = CFrame.lookAt(barPos, lookAtPos)
            bar.CFrame = bar.CFrame:Lerp(targetCFrame, 0.4)
            
            local highlightColor = Color3.new(1, 1, 1)
            bar.Color = Color3.fromRGB(10, 132, 255):Lerp(highlightColor, scale - 0.3)
        end
    end)
    
    local function Destroy()
        connection:Disconnect()
        for _, bar in ipairs(bars) do
            bar:Destroy()
        end
    end
    
    local function SetTarget(player)
        attachTarget = player
    end
    
    return {
        Connection = connection,
        Destroy = Destroy,
        SetTarget = SetTarget,
        GetBars = function() return bars end
    }
end

