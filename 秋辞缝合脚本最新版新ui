local ScriptCenterLeftGroup = Tabs.ScriptCenter:AddLeftGroupbox("脚本中心");
local ScriptCenterRightGroup = Tabs.ScriptCenter:AddRightGroupbox("脚本中心");
local leftIndex = 0;
local rightIndex = 0;
for _, category in ipairs(scriptCategories) do
        local targetGroup = ((leftIndex <= rightIndex) and ScriptCenterLeftGroup) or ScriptCenterRightGroup;
        if (((targetGroup == ScriptCenterLeftGroup) and (leftIndex > 0)) or ((targetGroup == ScriptCenterRightGroup) and (rightIndex > 0))) then
                targetGroup:AddLabel("--------------------------------------------------------------------------------");
        end
        targetGroup:AddLabel(category.GroupName);
        for _, btn in ipairs(category.List) do
                targetGroup:AddButton({Text=btn.Name,Func=function()
                        local success, err = pcall(function()
                                local scriptContent = game:HttpGet(btn.Url);
                                local func = loadstring(scriptContent);
                                if func then
                                        func();
                                end
                        end);
                end});
        end
        if (targetGroup == ScriptCenterLeftGroup) then
                leftIndex = leftIndex + 1;
        else
                rightIndex = rightIndex + 1;
        end
end

local SettingsGroup = Tabs.Settings:AddLeftGroupbox("系统设置");

local timeToggleBtn = SettingsGroup:AddButton("隐藏时间显示", function()
    local timeGui = game:GetService("CoreGui"):FindFirstChild("TimeDisplayGUI")
    
    if timeGui then
        local timeLabel = timeGui:FindFirstChild("TimeLabel")
        local toggleButton = timeGui:FindFirstChild("ToggleButton")
        
        if timeLabel then
            if timeLabel.Visible then
                timeLabel.Visible = false
                if toggleButton then
                    toggleButton.Text = "显示"
                    toggleButton.BackgroundColor3 = Color3.fromRGB(40, 160, 40)
                end
                
                timeToggleBtn:SetText("显示时间显示")
                Library:Notify("时间显示已隐藏", 3)
            else
                timeLabel.Visible = true
                if toggleButton then
                    toggleButton.Text = "隐藏"
                    toggleButton.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
                end
                
                timeToggleBtn:SetText("隐藏时间显示")
                Library:Notify("时间显示已显示", 3)
            end
        else
            Library:Notify("未找到时间标签", 3)
        end
    else
        Library:Notify("时间显示GUI未找到", 3)
    end
end)

