local MusicPlayer = {}
MusicPlayer.__index = MusicPlayer

function MusicPlayer.new()
    local self = setmetatable({}, MusicPlayer)
    self.sounds = {}
    self.currentSound = nil
    self.isPlaying = false
    self.volume = 0.5
    self.pitch = 1.0
    self.loop = false
    self.currentTrack = nil
    self.playlist = {}
    self.currentIndex = 1
    self.playbackMode = "sequential"
    
    return self
end

function MusicPlayer:createSound(trackId)
    if not trackId or trackId == "" then return end
    
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://" .. trackId
    sound.Volume = self.volume
    sound.Pitch = self.pitch
    sound.Looped = self.loop
    sound.RollOffMaxDistance = 1e6
    sound.RollOffMinDistance = 1e6
    sound.Playing = false
    sound.Parent = game:GetService("SoundService")
    
    return sound
end

function MusicPlayer:playTrack(track)
    if not track or not track.id then return false end
    
    if self.currentSound then
        self.currentSound:Stop()
        self.currentSound:Destroy()
        self.currentSound = nil
    end
    
    self.currentSound = self:createSound(track.id)
    if self.currentSound then
        self.currentSound:Play()
        self.isPlaying = true
        self.currentTrack = track
        return true
    end
    return false
end

function MusicPlayer:togglePlayPause()
    if not self.currentSound then return end
    
    if self.isPlaying then
        self.currentSound:Pause()
        self.isPlaying = false
    else
        if self.currentSound.IsPaused then
            self.currentSound:Resume()
        else
            self.currentSound:Play()
        end
        self.isPlaying = true
    end
end

function MusicPlayer:stop()
    if self.currentSound then
        if not isWindowMinimized then
            self.currentSound:Stop()
            self.currentSound:Destroy()
            self.currentSound = nil
        end
    end
    self.isPlaying = false
    self.currentTrack = nil
end

function MusicPlayer:next()
    if #self.playlist == 0 then return end
    
    if self.playbackMode == "random" then
        self.currentIndex = math.random(1, #self.playlist)
    else
        self.currentIndex = (self.currentIndex % #self.playlist) + 1
    end
    
    local nextTrack = self.playlist[self.currentIndex]
    if nextTrack then
        self:playTrack(nextTrack)
    end
end

function MusicPlayer:prev()
    if #self.playlist == 0 then return end
    
    if self.playbackMode == "random" then
        self.currentIndex = math.random(1, #self.playlist)
    else
        self.currentIndex = self.currentIndex - 1
        if self.currentIndex < 1 then
            self.currentIndex = #self.playlist
        end
    end
    
    local prevTrack = self.playlist[self.currentIndex]
    if prevTrack then
        self:playTrack(prevTrack)
    end
end

function MusicPlayer:setVolume(vol)
    self.volume = math.clamp(vol, 0, 1)
    if self.currentSound then
        self.currentSound.Volume = self.volume
    end
end

function MusicPlayer:setPitch(pitch)
    self.pitch = math.clamp(pitch, 0.1, 3)
    if self.currentSound then
        self.currentSound.Pitch = self.pitch
    end
end

function MusicPlayer:setLoop(loop)
    self.loop = loop
    if self.currentSound then
        self.currentSound.Looped = self.loop
    end
end

