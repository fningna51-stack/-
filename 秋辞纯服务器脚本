local UserInputService = game:GetService("UserInputService")
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.Space then
        player:togglePlayPause()
        if playPauseBtn then
            if player.isPlaying then
                playPauseBtn:SetTitle("暂停")
                playPauseBtn:SetIcon("pause")
            else
                playPauseBtn:SetTitle("播放")
                playPauseBtn:SetIcon("play")
            end
        end
    elseif input.KeyCode == Enum.KeyCode.Right then
        player:next()
        updateNowPlaying()
    elseif input.KeyCode == Enum.KeyCode.Left then
        player:prev()
        updateNowPlaying()
    elseif input.KeyCode == Enum.KeyCode.Up then
        player:setVolume(math.min(player.volume + 0.1, 1))
    elseif input.KeyCode == Enum.KeyCode.Down then
        player:setVolume(math.max(player.volume - 0.1, 0))
    end
end)

