function HoloLib:CreateWindow(config)
    local title = config.Title or "Vision UI"
    local MainPanel = CreateSpatialPanel(title, CFrame.new(-1.2, -0.2, -3.2), true)

    local MobileUI = Instance.new("ScreenGui")
