local function stopFly()
    pcall(function()
        local char = getCharacter()
        if char then
            local hum = getHumanoid()
            if hum then hum.PlatformStand = false end
            local root = getRootPart()
            if root then
                local bodyVel = root:FindFirstChild("QW_FlyVelocity")
                if bodyVel then bodyVel:Destroy() end
                local bodyGyro = root:FindFirstChild("QW_BodyGyro")
                if bodyGyro then bodyGyro:Destroy() end
            end
        end
    end)
end

local function flyLoop()
    pcall(function()
        local char = getCharacter()
        if not char then return end
        local hum = getHumanoid()
        local root = getRootPart()
        if not hum or not root then return end
        
        hum.PlatformStand = true
        hum.WalkSpeed = getgenv().QW.Speed
        
        local cam = Workspace.CurrentCamera
        if not cam then return end
        
        local moveDir = hum.MoveDirection
        if moveDir and moveDir.Magnitude > 0 then
            local bodyVel = root:FindFirstChild("QW_FlyVelocity")
            if not bodyVel then
                bodyVel = Instance.new("BodyVelocity")
                bodyVel.Name = "QW_FlyVelocity"
                bodyVel.MaxForce = Vector3.new(4000, 4000, 4000)
                bodyVel.Parent = root
            end
            bodyVel.Velocity = cam.CFrame.LookVector * moveDir.Z * getgenv().QW.Speed +
                               cam.CFrame.RightVector * moveDir.X * getgenv().QW.Speed +
                               Vector3.new(0, moveDir.Y * getgenv().QW.Speed, 0)
        end
        
        local bodyGyro = root:FindFirstChild("QW_BodyGyro")
        if not bodyGyro then
            bodyGyro = Instance.new("BodyGyro")
            bodyGyro.Name = "QW_BodyGyro"
            bodyGyro.MaxTorque = Vector3.new(4000, 4000, 4000)
            bodyGyro.P = 1000
            bodyGyro.Parent = root
        end
        bodyGyro.CFrame = cam.CFrame
    end)
end

local function noclipLoop()
    pcall(function()
        local char = getCharacter()
        if char then
            for _, part in ipairs(char:GetChildren()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
end

local function suckSharkLoop()
    pcall(function()
        local hrp = getRootPart()
        if not hrp then return end
        
        local sharks = getSharkObjects()
        for _, shark in ipairs(sharks) do
            local primaryPart = shark.PrimaryPart or shark:FindFirstChildWhichIsA("BasePart")
            if primaryPart then
                if shark:IsA("Model") then
                    shark:SetPrimaryPartCFrame(hrp.CFrame * CFrame.new(0, 15, -20))
                else
                    shark.CFrame = hrp.CFrame * CFrame.new(0, 15, -20)
                end
            end
        end
    end)
end

local function suckAllLoop()
    pcall(function()
        local hrp = getRootPart()
        if not hrp then return end
        
        local players = getAllPlayers()
        for _, player in ipairs(players) do
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local playerHRP = player.Character.HumanoidRootPart
                playerHRP.CFrame = hrp.CFrame * CFrame.new(0, 15, -20)
            end
        end
    end)
end

local function getSharkBlaster()
    pcall(function()
        local sharkBlaster = ReplicatedStorage:FindFirstChild("ClientViewportObjects")
        if sharkBlaster then
            sharkBlaster = sharkBlaster:FindFirstChild("Weapons")
            if sharkBlaster then
                sharkBlaster = sharkBlaster:FindFirstChild("SharkBlaster")
                if sharkBlaster then
                    local backpack = Player:FindFirstChild("Backpack")
                    if backpack and not backpack:FindFirstChild("SharkBlaster") then
                        sharkBlaster:Clone().Parent = backpack
                        WindUI:Notify({ Title = "获取成功", Content = "鲨鱼冲击波已添加到背包", Duration = 2 })
                    else
                        WindUI:Notify({ Title = "提示", Content = "背包中已有鲨鱼冲击波", Duration = 2 })
                    end
                else
                    WindUI:Notify({ Title = "获取失败", Content = "未找到鲨鱼冲击波", Duration = 2 })
                end
            end
        end
    end)
end

