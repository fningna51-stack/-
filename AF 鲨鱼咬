local function getCharacter()
    local success, result = pcall(function() return Player.Character end)
    return success and result or nil
end

local function getHumanoid()
    local success, result = pcall(function()
        local char = getCharacter()
        return char and char:FindFirstChildOfClass("Humanoid")
    end)
    return success and result or nil
end

local function getRootPart()
    local success, result = pcall(function()
        local char = getCharacter()
        return char and char:FindFirstChild("HumanoidRootPart")
    end)
    return success and result or nil
end

local function getSharkObjects()
    local sharks = {}
    pcall(function()
        local sharkFolder = Workspace:FindFirstChild("Sharks")
        if sharkFolder then
            for _, child in ipairs(sharkFolder:GetChildren()) do
                if child:IsA("Model") or child:IsA("Part") or child:IsA("MeshPart") then
                    table.insert(sharks, child)
                end
            end
        end
    end)
    return sharks
end

local function getSharkPlayers()
    local sharks = {}
    pcall(function()
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= Player then
                local team = player.Team
                if team and tostring(team):lower():find("shark") then
                    table.insert(sharks, player)
                end
            end
        end
    end)
    return sharks
end

local function getAllPlayers()
    local allPlayers = {}
    pcall(function()
        local sharkPlayers = {}
        for _, player in ipairs(Players:GetPlayers()) do
            local team = player.Team
            if team and tostring(team):lower():find("shark") then
                sharkPlayers[player] = true
            end
        end
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= Player and not sharkPlayers[player] then
                table.insert(allPlayers, player)
            end
        end
    end)
    return allPlayers
end

local function clearESP()
    for obj, instances in pairs(getgenv().QW.ESPObjects) do
        pcall(function()
            for _, inst in ipairs(instances) do
                if inst and inst.Parent then inst:Destroy() end
            end
        end)
    end
    getgenv().QW.ESPObjects = {}
end

local function createESP(obj, text)
    if not obj or getgenv().QW.ESPObjects[obj] then return end
    
    local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChildWhichIsA("BasePart")
    if not hrp then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "QW_SharkESP"
    highlight.Adornee = obj
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
    highlight.FillTransparency = 0.3
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = obj

    local bill = Instance.new("BillboardGui")
    bill.Name = "QW_SharkESP_Text"
    bill.Adornee = hrp
    bill.Size = UDim2.new(0, 100, 0, 30)
    bill.StudsOffset = Vector3.new(0, 3, 0)
    bill.AlwaysOnTop = true
    bill.Parent = obj

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextStrokeTransparency = 0
    label.TextSize = 14
    label.Parent = bill

    getgenv().QW.ESPObjects[obj] = {highlight, bill}
end

local function espLoop()
    pcall(function()
        for obj in pairs(getgenv().QW.ESPObjects) do
            if not obj or not obj.Parent then
                getgenv().QW.ESPObjects[obj] = nil
            end
        end
        
        local sharkPlayers = getSharkPlayers()
        for _, player in ipairs(sharkPlayers) do
            if player.Character then
                createESP(player.Character, "🦈 " .. player.Name)
            end
        end
        
        local sharkObjects = getSharkObjects()
        for _, shark in ipairs(sharkObjects) do
            createESP(shark, "🦈 鲨鱼")
        end
    end)
end

