        Callback = function(v)
        end
    })

    task.spawn(function()
        while wait(2) do
            if Engine.isRunning then
                local status = string.format("📊 已提取:%d | 已翻译:%d | 已应用:%d", 
                    Engine.extractCount, Engine.translateCount, Engine.localizeCount)
            end
        end
    end)
