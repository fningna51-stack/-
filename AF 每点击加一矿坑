local AutoRebirthRunning = false
local AutoRebirthConnection = nil
local function GetPlayerLevel()
    local player = game.Players.LocalPlayer
    if player:FindFirstChild("Level") then
        return player.Level.Value
    end    
    if player:FindFirstChild("leaderstats") and player.leaderstats:FindFirstChild("Level") then
        return player.leaderstats.Level.Value
    end
    return 0
end
local function GetRequiredLevel()
    local config = game:GetService("ReplicatedStorage"):FindFirstChild("GameConfig")
    if config and config:FindFirstChild("RebirthLevel") then
        return config.RebirthLevel.Value
    end    
    return 10
end
local function PerformRebirth()
    local args = {"Rebirth"}
    local success, errorMsg = pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("Server"):WaitForChild("Rebirth"):FireServer(unpack(args))
    end)
    
    if not success then
        warn("[自动重生] 重生失败: " .. tostring(errorMsg))
    else
        print("[自动重生] 已执行重生！")
    end
end
local function CheckAndRebirth()
    local playerLevel = GetPlayerLevel()
    local requiredLevel = GetRequiredLevel()
    
    if playerLevel >= requiredLevel then
        print(string.format("[自动重生] 等级 %d 已达到要求 %d 级，正在重生...", playerLevel, requiredLevel))
        PerformRebirth()
        task.wait(1)
    else
    end
end
function StartAutoRebirth()
    if AutoRebirthRunning then
        return
    end   
    AutoRebirthRunning = true
    print("[自动重生] 已启动")    
    CheckAndRebirth()    
    AutoRebirthConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if AutoRebirthRunning then
            CheckAndRebirth()
        end
    end)
end
function StopAutoRebirth()
    AutoRebirthRunning = false    
    if AutoRebirthConnection then
        AutoRebirthConnection:Disconnect()
        AutoRebirthConnection = nil
    end  
    print("[自动重生] 已停止")
end
