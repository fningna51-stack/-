local isPlanting = false
local currentSaplingIndex = 1
local saplingPositions = {}

local function generatePlantPositions()
    local positions = {}
    local halfSize = plantingConfig.size / 2
    local playerPosition = Vector3.new(0.649, plantingConfig.height, -3.8)
    
    if plantingConfig.shape == "square" then
        for x = -halfSize, halfSize, plantingConfig.spacing do
            table.insert(positions, Vector3.new(playerPosition.X + x, playerPosition.Y, playerPosition.Z + halfSize))
        end
        for z = halfSize, -halfSize, -plantingConfig.spacing do
            table.insert(positions, Vector3.new(playerPosition.X + halfSize, playerPosition.Y, playerPosition.Z + z))
        end
        for x = halfSize, -halfSize, -plantingConfig.spacing do
            table.insert(positions, Vector3.new(playerPosition.X + x, playerPosition.Y, playerPosition.Z - halfSize))
        end
        for z = -halfSize, halfSize, plantingConfig.spacing do
            table.insert(positions, Vector3.new(playerPosition.X - halfSize, playerPosition.Y, playerPosition.Z + z))
        end
    elseif plantingConfig.shape == "circle" then
        local radius = halfSize
        local pointCount = math.floor(2 * math.pi * radius / plantingConfig.spacing)
        for i = 1, pointCount do
            local angle = (i / pointCount) * 2 * math.pi
            table.insert(positions, Vector3.new(playerPosition.X + radius * math.cos(angle), playerPosition.Y, playerPosition.Z + radius * math.sin(angle)))
        end
    else
        table.insert(positions, playerPosition)
    end
    return positions
end

FarmingGroup:AddToggle("AutoPlant", {
    Text = "自动种植",
    Default = false,
    Callback = function(Value)
        if Value then
            saplingPositions = generatePlantPositions()
            currentSaplingIndex = 1
            task.spawn(function()
                while Value do
                    if not isPlanting then
                        isPlanting = true
                        local remoteEvents = game:GetService("ReplicatedStorage").RemoteEvents
                        local tempStorage = game:GetService("ReplicatedStorage").TempStorage
                        local sapling = tempStorage:FindFirstChild("Sapling") or workspace.Items:FindFirstChild("Sapling")
                        
                        if sapling and saplingPositions[currentSaplingIndex] then
                            pcall(function()
                                remoteEvents.StopDraggingItem:FireServer(sapling)
                                task.wait(0.1)
                                remoteEvents.RequestPlantItem:InvokeServer(sapling, saplingPositions[currentSaplingIndex])
                            end)
                            currentSaplingIndex = currentSaplingIndex + 1
                            if currentSaplingIndex > #saplingPositions then currentSaplingIndex = 1 end
                        end
                        isPlanting = false
                    end
                    task.wait(plantingConfig.delay)
                end
            end)
        end
    end
})

