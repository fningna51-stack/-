local function TeleportToPosition(cf)
    local hrp = GetHRP()
    if not hrp or not cf then return end
    if Config.MoveMode == "传送" then
        hrp.CFrame = cf
    else
        local distance = (hrp.Position - cf.Position).Magnitude
        local duration = math.clamp(distance / Config.MoveSpeed, 0.05, 2)
        TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = cf}):Play()
    end
end

local function TeleportToNPC(npcObj)
    local hrp = GetHRP()
    if not hrp or not npcObj then return end
    local cf = npcObj:IsA("Model") and npcObj:GetPivot() or npcObj.CFrame
    TeleportToPosition(cf * CFrame.new(0, 0, -3))
end

local function FindClosestMob(mobType, specificMobs)
    if not enemiesFolder then return nil end
    local keyword = mobType:lower()
    local hrp = GetHRP()
    local closest, closestPrimary = nil, nil
    local closestDist = math.huge
    for _, v in pairs(enemiesFolder:GetChildren()) do
        if specificMobs then
            local isSpecific = false
            for _, mobName in ipairs(specificMobs) do
                if v.Name == mobName then isSpecific = true break end
            end
            if not isSpecific then
            end
        else
            if not string.find(v.Name:lower(), keyword, 1, true) then
            end
        end
        local hum = v:FindFirstChildOfClass("Humanoid")
        local primary = v.PrimaryPart or v:FindFirstChild("HumanoidRootPart")
        if hum and hum.Health > 0 and primary then
            if hrp then
                local dist = (primary.Position - hrp.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = v
                    closestPrimary = primary
                end
            else
                return v, primary
            end
        end
    end
    return closest, closestPrimary
end

local function FindClosestFarmMob(mobNames)
    if not enemiesFolder then return nil end
    local hrp = GetHRP()
    local closest, closestPrimary = nil, nil
    local closestDist = math.huge
    for _, mobName in ipairs(mobNames) do
        for _, v in pairs(enemiesFolder:GetChildren()) do
            if string.find(v.Name:lower(), mobName:lower(), 1, true) then
                local hum = v:FindFirstChildOfClass("Humanoid")
                local primary = v.PrimaryPart or v:FindFirstChild("HumanoidRootPart")
                if hum and hum.Health > 0 and primary then
                    if hrp then
                        local dist = (primary.Position - hrp.Position).Magnitude
                        if dist < closestDist then
                            closestDist = dist
                            closest = v
                            closestPrimary = primary
                        end
                    else
                        return v, primary
                    end
                end
            end
        end
    end
    return closest, closestPrimary
end

local function FindClosestTimedBoss()
    if not enemiesFolder then return nil end
    local hrp = GetHRP()
    local closest, closestPrimary = nil, nil
    local closestDist = math.huge
    for _, v in pairs(enemiesFolder:GetChildren()) do
        local bossName = v.Name
        local isSelected = false
        if type(Config.SelectedTimedBosses) == "table" then
            if table.find(Config.SelectedTimedBosses, "All") then
                isSelected = table.find(TimedBosses, bossName) ~= nil
            else
                isSelected = table.find(Config.SelectedTimedBosses, bossName) ~= nil
            end
        else
            isSelected = Config.SelectedTimedBosses == "All" and table.find(TimedBosses, bossName) ~= nil or Config.SelectedTimedBosses == bossName
        end
        if isSelected then
            local hum = v:FindFirstChildOfClass("Humanoid")
            local primary = v.PrimaryPart or v:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and primary and hrp then
                local dist = (primary.Position - hrp.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = v
                    closestPrimary = primary
                end
            end
        end
    end
    return closest, closestPrimary
end

