for i = 1, 4 do
    local weaponList = getWeaponList()
    slots[i] = {
        enabled = false,
        selectedWeapon = #weaponList > 0 and weaponList[1] or "",
        interval = 0.3,
    }
    local SlotSection = EquipTab:Section({ Title = "装备栏 Slot " .. i })
    SlotSection:Toggle({
        Title = "自动装备",
        Value = false,
        Callback = function(v)
            slots[i].enabled = v
            if v then startSlotThread(i) elseif slotThreads[i] then task.cancel(slotThreads[i]) end
        end
    })
    local dropdown = SlotSection:Dropdown({
        Title = "选择武器",
        Values = weaponList,
        Value = #weaponList > 0 and weaponList[1] or "",
        Callback = function(v)
            slots[i].selectedWeapon = v
            if slots[i].enabled then startSlotThread(i) end
        end
    })
    SlotSection:Slider({
        Title = "装备间隔(秒)",
        Value = {Min = 0.1, Max = 5, Default = 0.3},
        Callback = function(v)
            slots[i].interval = v
            if slots[i].enabled then startSlotThread(i) end
        end
    })
    SlotSection:Button({
        Title = "刷新武器列表",
        Icon = "refresh-cw",
        Callback = function()
            local newList = getWeaponList()
            dropdown:SetValues(newList)
            if #newList > 0 then
                if not table.find(newList, slots[i].selectedWeapon) then
                    dropdown:SetValue(newList[1])
                    slots[i].selectedWeapon = newList[1]
                end
                WindUI:Notify({Title = "Slot " .. i, Content = "武器列表已刷新", Duration = 2})
            else
                WindUI:Notify({Title = "Slot " .. i, Content = "背包无武器", Duration = 2})
            end
        end
    })
end

lp.CharacterAdded:Connect(function()
    task.wait(1)
    for i = 1, 4 do
        if slots[i] and slots[i].enabled then startSlotThread(i) end
    end
end)

