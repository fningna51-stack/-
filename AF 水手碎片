local function getToolByName(name)
    local backpack = lp:FindFirstChild("Backpack")
    if not backpack then return nil end
    for _, v in ipairs(backpack:GetChildren()) do
        if v:IsA("Tool") and v.Name == name then return v end
    end
    return nil
end

local function equipSlot(slotIndex)
    local slot = slots[slotIndex]
    if not slot or not slot.enabled then return end
    local char = lp.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    local tool = getToolByName(slot.selectedWeapon)
    if not tool then return end
    local equipped = char:FindFirstChildOfClass("Tool")
    if equipped and equipped.Name == tool.Name then return end
    if equipWeaponRemote then
        equipWeaponRemote:FireServer(tool)
    else
        humanoid:EquipTool(tool)
    end
end

local function startSlotThread(slotIndex)
    if slotThreads[slotIndex] then task.cancel(slotThreads[slotIndex]) end
    local slot = slots[slotIndex]
    if not slot or not slot.enabled then return end
    slotThreads[slotIndex] = task.spawn(function()
        while slot.enabled do
            equipSlot(slotIndex)
            task.wait(slot.interval)
        end
    end)
end

local function BuyItem()
    local hrp = GetHRP()
    if not hrp then WindUI:Notify({Title = "错误", Content = "无法获取角色位置", Duration = 3}) return end
    SaveOriginalPosition()
    local selectedItem = nil
    for _, item in ipairs(ShopItems) do
        if item.name == Config.SelectedItem then selectedItem = item break end
    end
    if not selectedItem then WindUI:Notify({Title = "错误", Content = "未找到物品信息", Duration = 3}) return end
    TeleportToPosition(CFrame.new(selectedItem.position))
    task.wait(0.5)
    if selectedItem.type == "Kanata" then
        local npc = workspace.ServiceNPCs and workspace.ServiceNPCs:FindFirstChild("Katana")
        if npc and npc.HumanoidRootPart then
            local prompt = npc.HumanoidRootPart:FindFirstChild("KatanaShopPrompt")
            if prompt then fireproximityprompt(prompt) end
        end
    elseif selectedItem.type == "DarkBlade" then
        local npc = workspace.ServiceNPCs and workspace.ServiceNPCs:FindFirstChild("DarkBladeNPC")
        if npc and npc.HumanoidRootPart then
            local prompt = npc.HumanoidRootPart:FindFirstChild("DarkBladeShopPrompt")
            if prompt then fireproximityprompt(prompt) end
        end
    elseif selectedItem.type == "ObservationHaki" then
        local npc = workspace.ServiceNPCs and workspace.ServiceNPCs:FindFirstChild("ObservationBuyer")
        if npc and npc.HumanoidRootPart then
            local prompt = npc.HumanoidRootPart:FindFirstChild("ObservationHakiPrompt")
            if prompt then fireproximityprompt(prompt) end
        end
    end
    task.wait(1)
    if originalPosition then TeleportToPosition(originalPosition) end
    WindUI:Notify({Title = "购买", Content = "已完成", Duration = 2})
end

